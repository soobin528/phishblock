{
  "manifest_version": 3,
  "name": "PhishingBlock",
  "version": "1.0.0",
  "description": "URL 피싱 위험도를 안내하는  확장 프로그램",
  "action": {
    "default_title": "PhishingBlock",
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab", "tabs", "storage"],
  "host_permissions": ["http://127.0.0.1:5000/*", "http://localhost:5000/*"],
  "background": {
    "service_worker": "service_worker.js"
  }
}
